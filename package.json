{
  "name": "video-split-tool-v3",
  "version": "3.0.0",
  "description": "Video Split Tool V3 - Electron + React + FastAPI",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:web": "vite build",
    "build:backend": "python build/build_backend.py --clean",
    "download:ffmpeg": "python build/download_ffmpeg.py all",
    "preview": "vite preview",
    "electron:dev": "npm run build:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:dev:watch": "tsc -p tsconfig.electron.json --watch",
    "electron:build": "npm run build:electron && vite build && electron-builder",
    "dist": "npm run build:electron && npm run build:web && electron-builder",
    "dist:win": "npm run build:backend && npm run download:ffmpeg && electron-builder --win",
    "dist:mac": "npm run build:backend && npm run download:ffmpeg && electron-builder --mac",
    "pack:win": "python build/build_installer.py --win",
    "pack:mac": "python build/build_installer.py --mac",
    "lint": "eslint src --ext ts,tsx",
    "test": "vitest",
    "test:backend": "cd backend && python -m pytest"
  },
  "dependencies": {
    "antd": "^5.22.0",
    "@ant-design/icons": "^5.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0",
    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.videosplittool.v3",
    "productName": "VideoSplitTool",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "dist-backend/**/*",
      "build/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-backend",
        "to": "backend"
      },
      {
        "from": "ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VideoSplitTool V3",
      "deleteAppDataOnUninstall": true,
      "unicode": true
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.video",
      "icon": "public/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  }
}
